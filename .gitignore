# Terraform local files
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform lock file decision:
# Keep .terraform.lock.hcl committed for provider consistency.
# Do NOT ignore it.

